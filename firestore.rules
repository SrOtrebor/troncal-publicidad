rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Función para verificar si es el Admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'HbJXARWENmYQA3CRFZcGTltk1C73';
    }

    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /editions/{editionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /slots/{slotId} {
      allow read: if true;
      // Cualquier usuario puede reservar/comprar (Checkout actualiza el slot)
      allow write: if true; 
    }
    
    match /clients/{clientId} {
      allow read: if isAdmin();
      // Cualquier usuario que compra es guardado automáticamente
      allow write: if true;
    }
    
    match /notifications/{notifId} {
      allow read: if isAdmin();
      // El checkout genera notificaciones de venta/subida de material
      allow write: if true;
    }
  }
}
