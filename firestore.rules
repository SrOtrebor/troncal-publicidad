rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ REGLAS DE DESARROLLO (Modo Prueba)
    // Permite lectura y escritura a cualquier usuario por 30 días.
    // Una vez implementado Firebase Auth para el panel de Admin,
    // cambiaremos estas reglas para proteger los datos.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 15);
    }
    
    /* 
    REGLAS PARA PRODUCCIÓN (Las usaremos más adelante):
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Solo admin
    }
    match /editions/{editionId} {
      allow read: if true;
      allow write: if request.auth != null; // Solo admin
    }
    match /slots/{slotId} {
      allow read: if true;
      // Checkout necesita actualizar el slot para reservarlo/comprarlo
      allow write: if true; 
    }
    match /notifications/{notifId} {
      allow read: if request.auth != null; // Solo admin
      allow write: if true; // El sistema de pago crea notificaciones
    }
    */
  }
}
