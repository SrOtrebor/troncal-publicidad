rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Función para verificar si es el Admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'HbJXARWENmYQA3CRFZcGTltk1C73';
    }

    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /editions/{editionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /slots/{slotId} {
      allow read: if true;
      allow create: if true; // Permitido para CustomCheckout
      allow update, delete: if isAdmin(); // Solo admin
    }

    match /customLinks/{linkId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if true; // Permitido para marcar como usado en CustomCheckout
    }
    
    match /clients/{clientId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Cloud Functions creará los clientes
    }
    
    match /notifications/{notifId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Cloud Functions creará las notificaciones
    }

    // Regla Catch-all para bloquear acceso a colecciones no definidas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
